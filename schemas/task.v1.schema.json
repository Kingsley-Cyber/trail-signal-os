{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task.v1.schema.json",
  "title": "Task v1",
  "description": "Queue task reference (Redis stream message + Postgres durable row).",
  "type": "object",
  "required": [
    "task_id",
    "job_id",
    "lane",
    "priority",
    "attempt",
    "status",
    "idempotency_key",
    "payload_ref",
    "created_at",
    "provenance",
    "schema_version"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^tsk_[a-zA-Z0-9_-]+$"
    },
    "job_id": {
      "type": "string",
      "pattern": "^job_[a-zA-Z0-9_-]+$"
    },
    "task_kind": { "type": "string" },
    "lane": {
      "type": "string",
      "minLength": 1
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "enum": [
        "PENDING",
        "READY",
        "LEASED",
        "RUNNING",
        "SUCCEEDED",
        "RETRY_WAIT",
        "BLOCKED",
        "FAILED",
        "DEAD_LETTER"
      ]
    },
    "idempotency_key": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "payload_ref": {
      "type": "string",
      "minLength": 1
    },
    "traceparent": { "type": "string" },
    "retry_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "lease_owner": { "type": ["string", "null"] },
    "fencing_token": { "type": ["integer", "null"] },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "type": "object",
      "required": ["schema_version", "config_hash", "created_at"],
      "properties": {
        "schema_version": { "const": "task.v1" },
        "config_hash": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "schema_version": {
      "const": "task.v1"
    }
  },
  "additionalProperties": false
}
