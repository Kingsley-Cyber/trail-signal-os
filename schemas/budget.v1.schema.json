{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "budget.v1.schema.json",
  "title": "Budget v1",
  "description": "Per-job resource budget (config/limits.yaml default_budgets shape).",
  "type": "object",
  "required": [
    "max_queries",
    "max_fetched_urls",
    "per_domain_urls",
    "browser_pages",
    "media_items",
    "max_bytes",
    "deadline_minutes",
    "max_attempts",
    "llm_budget",
    "schema_version"
  ],
  "properties": {
    "max_queries": {
      "type": "integer",
      "minimum": 0
    },
    "max_fetched_urls": {
      "type": "integer",
      "minimum": 0
    },
    "per_domain_urls": {
      "type": "integer",
      "minimum": 0
    },
    "browser_pages": {
      "type": "integer",
      "minimum": 0
    },
    "media_items": {
      "type": "integer",
      "minimum": 0
    },
    "max_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "deadline_minutes": {
      "type": "integer",
      "minimum": 1
    },
    "max_attempts": {
      "type": "integer",
      "minimum": 1
    },
    "llm_budget": {
      "type": "object",
      "required": ["max_calls", "max_tokens", "max_usd"],
      "properties": {
        "max_calls": { "type": "integer", "minimum": 0 },
        "max_tokens": { "type": "integer", "minimum": 0 },
        "max_usd": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "schema_version": {
      "const": "budget.v1"
    }
  },
  "additionalProperties": false
}
